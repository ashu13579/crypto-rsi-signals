# Application
APP_NAME=Crypto RSI Signals
APP_VERSION=1.0.0
ENVIRONMENT=development
DEBUG=True

# Server
HOST=0.0.0.0
PORT=8000

# Database
DATABASE_URL=sqlite:///./crypto_rsi.db
# For PostgreSQL: postgresql://user:password@localhost/crypto_rsi

# Security
SECRET_KEY=your-secret-key-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# CORS
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8080

# Exchange
DEFAULT_EXCHANGE=binance
EXCHANGE_TESTNET=False

# RSI Settings
DEFAULT_RSI_PERIOD=14
DEFAULT_RSI_OVERSOLD=30
DEFAULT_RSI_OVERBOUGHT=70
DEFAULT_TIMEFRAME=1h

# Scanner
SCAN_INTERVAL_SECONDS=60
DEFAULT_SYMBOLS=BTC/USDT,ETH/USDT,BNB/USDT,XRP/USDT,ADA/USDT,SOL/USDT,DOT/USDT,DOGE/USDT,AVAX/USDT,MATIC/USDT,LINK/USDT,UNI/USDT,ATOM/USDT,LTC/USDT,ETC/USDT,XLM/USDT,ALGO/USDT,VET/USDT,FIL/USDT,TRX/USDT

# Redis (optional, for caching)
REDIS_URL=redis://localhost:6379/0
CACHE_ENABLED=False

# Logging
LOG_LEVEL=INFO
LOG_FILE=logs/app.log

# Rate Limiting
RATE_LIMIT_ENABLED=True
RATE_LIMIT_PER_MINUTE=60
